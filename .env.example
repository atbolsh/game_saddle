# Neo4j (local, bolt-based). No external NAMS API key needed.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Gemma 4 E4B multimodal model.
GEMMA_MODEL_ID=google/gemma-4-E4B-it
GEMMA_DTYPE=bfloat16
GEMMA_DEVICE=auto
# High ceiling so the agent can reason and chain several moves without being
# truncated mid-turn (it stops at its end-of-turn token well before this).
GEMMA_MAX_NEW_TOKENS=2048

# Local sentence-transformers embedding model for NAMS.
NAMS_EMBEDDING=sentence-transformers/all-MiniLM-L6-v2

# Filesystem layout for game snapshot images.
AGENT_IMAGE_DIR=memory_images

# Game defaults. 768 saturates Gemma 4's default 280-soft-token image budget
# (the processor upscales smaller squares to 768x768 anyway, so rendering
# natively at 768 adds real detail at zero token cost).
GAME_SIZE=768
MAX_SOLVE_STEPS=200

# HuggingFace token (only needed if the model weights are gated, as Gemma's
# are). Setting it HERE is enough: every entry point (runner, notebooks,
# scripts/setup_env.sh downloads) loads this file via python-dotenv -- no
# shell export or `huggingface-cli login` required.
# HF_TOKEN=hf_xxx
